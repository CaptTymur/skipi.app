{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skipi",
  "version": "0.4.11",
  "identifier": "app.skipi.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Skipi — Maritime Document Management",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CaptTymur/skipi.app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyQTBGRDFCNTc0OEMyQjgKUldTNHdraFhHLzJnWXNkekpvdmNBa2xRbVlhMHFsczdCMXB1ZTZTcUk0ZWxoMkN3SHVYVmZWNm8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Tymur Rudov",
    "copyright": "Copyright © 2026 Tymur Rudov. Closed beta.",
    "category": "Productivity",
    "shortDescription": "Maritime document management for seafarers",
    "longDescription": "Skipi is a local-first document vault for seafarers and ship managers. Store certificates, track expiry dates, build shareable packages — all data stays on your computer.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
